# === BROKER CONFIGURATION ===
# Set ACTIVE_BROKER to one of: alpaca | robinhood | etrade
ACTIVE_BROKER=alpaca

# --- Alpaca ---
ALPACA_API_KEY=your_alpaca_api_key
ALPACA_SECRET_KEY=your_alpaca_secret_key
ALPACA_PAPER=true   # true = paper trading, false = live

# --- Robinhood ---
ROBINHOOD_USERNAME=your_email@example.com
ROBINHOOD_PASSWORD=your_password
ROBINHOOD_MFA_CODE=   # leave blank; you'll be prompted or use TOTP below
ROBINHOOD_TOTP_SECRET=  # optional: base32 TOTP secret for 2FA automation

# --- E-Trade ---
ETRADE_CONSUMER_KEY=your_consumer_key
ETRADE_CONSUMER_SECRET=your_consumer_secret
ETRADE_SANDBOX=true  # true = sandbox, false = production

# === DATA SOURCES ===
CAPITOL_TRADES_ENABLED=true
QUIVER_QUANT_API_KEY=   # optional: quiverquant.com API for congress trades
ALPHA_VANTAGE_API_KEY=  # optional: Alpha Vantage News Sentiment
POLYGON_API_KEY=        # optional: Polygon.io reference/news
FMP_API_KEY=            # optional: Financial Modeling Prep profile data
EODHD_API_KEY=          # optional: EODHD fundamentals/quotes
FRED_API_KEY=           # optional: FRED (St. Louis Fed) macro data
TIINGO_API_KEY=         # optional: Tiingo company metadata/price
LUNARCRUSH_API_KEY=     # optional: LunarCrush social/sentiment data

# Alternative-data provider toggles
ALT_ENABLE_CAPITOL_TRADES=true
ALT_ENABLE_OPENINSIDER=true
ALT_ENABLE_WHALEWISDOM=true
ALT_ENABLE_QUIVER_QUANTITATIVE=true
ALT_ENABLE_ALPHA_VANTAGE=true
ALT_ENABLE_POLYGON=true
ALT_ENABLE_FMP=true
ALT_ENABLE_EODHD=true
ALT_ENABLE_FRED=true
ALT_ENABLE_TIINGO=true
ALT_ENABLE_LUNARCRUSH=true

# Alternative-data weights (0.0 - 3.0 typical)
ALT_WEIGHT_CAPITOL_TRADES=1.00
ALT_WEIGHT_OPENINSIDER=1.00
ALT_WEIGHT_WHALEWISDOM=0.35
ALT_WEIGHT_QUIVER_QUANTITATIVE=0.90
ALT_WEIGHT_ALPHA_VANTAGE=0.85
ALT_WEIGHT_POLYGON=0.60
ALT_WEIGHT_FMP=0.35
ALT_WEIGHT_EODHD=0.55
ALT_WEIGHT_FRED=0.45
ALT_WEIGHT_TIINGO=0.25
ALT_WEIGHT_LUNARCRUSH=0.50

# === APP SETTINGS ===
REFRESH_INTERVAL_MINUTES=15
SIGNAL_LOOKBACK_DAYS=90
